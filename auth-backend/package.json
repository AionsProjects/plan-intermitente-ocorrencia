{
  "name": "plano-intermitentes-auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend de autenticacao (SSO Google Workspace + Postgres) do app de Intermitentes",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "test": "node --env-file=.env --import tsx --test src/**/*.test.ts",
    "start": "node dist/server.js",
    "migrate": "node --env-file=.env --import tsx src/scripts/migrate.ts",
    "seed": "node --env-file=.env --import tsx src/scripts/seed.ts",
    "registrar-boards": "node --env-file=.env --import tsx src/scripts/registrar-boards.ts",
    "token:servico": "node --env-file=.env --import tsx src/scripts/token-servico.ts",
    "importar:convocacoes": "node --env-file=.env --import tsx src/scripts/importar-convocacoes.ts",
    "migrate:dist": "node dist/scripts/migrate.js",
    "seed:dist": "node dist/scripts/seed.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^9.4.0",
    "fastify": "^5.2.1",
    "google-auth-library": "^9.15.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
