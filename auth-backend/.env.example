# Backend de autenticacao — envs lidas em RUNTIME (nao sao VITE_*; nunca vao pro bundle).
PORT=3000

# Postgres (banco unico, schema pi). Valor real so na env do Vercel / .env (gitignored).
# Dev local: postgres://postgres:senha@localhost:5432/db
DATABASE_URL=postgres://USUARIO:SENHA@SEU_HOST:PORTA/BANCO
# 1 se o Postgres exigir SSL (cloudfy atual NAO exige -> 0)
DB_SSL=0

# Google OAuth (Workspace contatoserv.com.br) — criar Client ID tipo "Web application"
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=troque_este_secret
# Redirect autorizado no Google Cloud Console:
#   local: http://localhost:8081/auth/google/callback
#   prod:  http://192.168.0.41:8081/auth/google/callback
OAUTH_REDIRECT_URI=http://localhost:8081/auth/google/callback

# Pra onde mandar apos login OK
APP_BASE_URL=/

# Restricao de dominio (quem pode logar por auto-provisao)
AUTH_ALLOWED_DOMAIN=contatoserv.com.br

# Sessao
SESSION_COOKIE_NAME=pi_sess
SESSION_TTL_DIAS=10
# Cookie Secure: 0 na VM HTTP puro; 1 so quando tiver TLS
COOKIE_SECURE=0

# 1o Admin (CONFIRMAR email real). RH/OP vem do onboarding; DP/Admin promovidos no painel.
SEED_ADMIN_EMAIL=admin@contatoserv.com.br

# Bypass de login Google p/ testes locais (NUNCA 1 em producao)
AUTH_DEV_BYPASS=0
