# Vazio = modo MOCK (uuids mock-* e protocolos PROT-DEMO-/PROT-TEST-).
# Base dos webhooks do n8n (sem barra final).
#
# Dois hosts pra coexistência durante migração:
# - VITE_N8N_BASE_URL: n8n novo (WFs do split, atestados, ler, finalizar)
# - VITE_N8N_ANTIGO_BASE_URL: n8n antigo (WFs que ainda não migraram —
#   convocar legado, busca empregado RM via BEN 2, cancelar convocação)
#
# Quando ANTIGO não definido, features que tentam usar caem no NOVO
# (fallback `VITE_N8N_ANTIGO_BASE_URL || VITE_N8N_BASE_URL` em api.ts).

VITE_N8N_BASE_URL=https://aionscorp-n8n.cloudfy.live/webhook
VITE_N8N_ANTIGO_BASE_URL=https://antigoaionscorp-n8n.cloudfy.live/webhook

# =============================================================
# Auth (backend Fastify + Postgres) — lidas pelo docker-compose em RUNTIME.
# NAO sao VITE_* (nunca vao pro bundle do frontend). Detalhe em auth-backend/.env.example.
# =============================================================
# Postgres CLOUDFY (banco unico, schema pi). NAO ha db local no compose.
DATABASE_URL=postgres://postgres:SUA_SENHA@aionscorp-postgres.cloudfy.live:8216/db
# 1 se o Postgres exigir SSL (cloudfy atual NAO exige -> 0)
DB_SSL=0
# Google OAuth (Workspace contatoserv.com.br) — Client ID tipo "Web application"
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=troque_este_secret
# Redirect autorizado: local http://localhost:8081/auth/google/callback | prod http://192.168.0.41:8081/auth/google/callback
OAUTH_REDIRECT_URI=http://192.168.0.41:8081/auth/google/callback
APP_BASE_URL=/
AUTH_ALLOWED_DOMAIN=contatoserv.com.br
SESSION_COOKIE_NAME=pi_sess
SESSION_TTL_DIAS=10
# 0 na VM HTTP puro; 1 so com TLS
COOKIE_SECURE=0
# 1o Admin (CONFIRMAR email real). RH/OP via onboarding; DP/Admin promovidos no painel.
SEED_ADMIN_EMAIL=admin@contatoserv.com.br
# Bypass login Google p/ teste local (NUNCA 1 em producao)
AUTH_DEV_BYPASS=0
